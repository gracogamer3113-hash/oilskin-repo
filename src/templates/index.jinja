{% extends 'layout.jinja' %}

{% block title %}Inicio - OilSkin{% endblock %}

{% block content %}
<header
    style="background-image: linear-gradient(rgba(0,0,0,0.8), rgba(0,0,0,0.8)), url('{{ url_for('static', filename='img/palmas.png') }}'); background-size: cover; background-repeat: no-repeat; background-position: center;"
    class="bg-cover bg-no-repeat bg-center">
    <div class="flex flex-col lg:flex-row justify-center items-center gap-8 py-12 px-4">
        <img src="{{ url_for('static', filename='img/logo.png') }}" alt="OIL SKIN Logo"
            class="w-40 h-40 lg:w-56 lg:h-56 rounded-full object-cover shadow-xl">
        <div class="flex flex-col gap-6 text-center lg:text-left">
            <h1 class="text-5xl lg:text-7xl font-bold text-white">OIL SKIN</h1>
            <p class="text-lg lg:text-xl text-gray-200 leading-relaxed max-w-lg">Lorem ipsum dolor sit amet consectetur
                adipisicing elit. Aliquid numquam asperiores eligendi cupiditate delectus at debitis dignissimos minima
                aperiam aliquam quas ratione saepe quasi, necessitatibus iste? Molestias id odio accusantium?</p>
            <a href="#"
                class="inline-block bg-[#CEB06E] hover:bg-[#b89d5a] text-black font-bold py-3 px-8 rounded-full transition duration-300 w-fit mx-auto lg:mx-0">¡Contactanos!</a>
        </div>
    </div>
</header>
{% endblock %}